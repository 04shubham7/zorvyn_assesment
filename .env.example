# Environment Configuration
# Copy this to .env and fill in with your values

NODE_ENV=development
PORT=5000

# Neon Database (PostgreSQL Serverless)
# Get your CONNECTION STRING from Neon dashboard at https://console.neon.tech/
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxxx.neon.tech/finance_dashboard?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000
